{
  "manifest_version": 3,
  "name": "Academic Copilot",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://academicopilot.onrender.com/*",
    "*://*.iiit.ac.in/*",
    "*://*.google.com/*"
  ]
}